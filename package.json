{
  "name": "@sungwon_choi/codex-failover",
  "version": "0.0.1",
  "private": false,
  "author": "s-w-choi <csw2757@naver.com>",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "bin": {
    "codex-failover": "./apps/router-backend/dist/cli.js"
  },
  "files": [
    "apps/router-backend/dist",
    "apps/router-tray/dist",
    "dist/"
  ],
  "scripts": {
    "build": "pnpm -r --filter @codex-failover/shared --filter @codex-failover/provider-core --filter @codex-failover/credential-store --filter @codex-failover/usage-tracker --filter @codex-failover/test-harness --filter @codex-failover/router-backend --filter @codex-failover/router-tray build",
    "start": "pnpm --filter @codex-failover/router-backend start",
    "tray": "pnpm --filter @codex-failover/router-tray start",
    "cli": "tsx apps/router-backend/src/cli.ts",
    "dev": "concurrently -k -n backend,tray,harness \"pnpm dev:backend\" \"pnpm dev:tray\" \"pnpm harness:start\"",
    "dev:backend": "PORT=8788 pnpm --filter @codex-failover/router-backend dev",
    "dev:tray": "pnpm --filter @codex-failover/router-tray dev",
    "harness:start": "pnpm --filter @codex-failover/test-harness dev",
    "harness:reset": "pnpm --filter @codex-failover/test-harness reset",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "pnpm --filter @codex-failover/provider-core --filter @codex-failover/shared --filter @codex-failover/credential-store --filter @codex-failover/usage-tracker test:unit",
    "test:integration": "pnpm --filter @codex-failover/router-backend --filter @codex-failover/test-harness test:integration",
    "test:e2e": "pnpm --filter @codex-failover/router-backend --filter @codex-failover/test-harness test:e2e",
    "lint": "pnpm -r --filter @codex-failover/router-backend --filter @codex-failover/router-tray --filter @codex-failover/provider-core --filter @codex-failover/shared --filter @codex-failover/test-harness --filter @codex-failover/credential-store --filter @codex-failover/usage-tracker lint",
    "typecheck": "pnpm -r --filter @codex-failover/router-backend --filter @codex-failover/router-tray --filter @codex-failover/provider-core --filter @codex-failover/shared --filter @codex-failover/test-harness --filter @codex-failover/credential-store --filter @codex-failover/usage-tracker typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "codex:install": "tsx scripts/install-codex-config.ts",
    "codex:restore": "tsx scripts/restore-codex-config.ts",
    "security:scan": "tsx scripts/verify.ts --security-scan",
    "pack": "pnpm build && npm pack --pack-destination dist/",
    "publish:dry": "pnpm build && npm publish --dry-run",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@codex-failover/credential-store": "^0.1.0",
    "@codex-failover/provider-core": "^0.1.0",
    "@codex-failover/shared": "^0.1.0",
    "@codex-failover/usage-tracker": "^0.1.0",
    "@hono/node-server": "^1.13.8",
    "dotenv": "^16.4.7",
    "electron": "^33.0.0",
    "hono": "^4.6.17"
  }
}
