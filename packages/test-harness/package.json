{
  "name": "@codex-failover/test-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "reset": "tsx src/index.ts --reset",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --passWithNoTests",
    "test:e2e": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.17"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
